+
+# NXP EasyMesh support
+# Enables loop avoidance mechanism in mesh backhaul networks using vendor IE
+# mesh index, and skips GAS/Public Action frame registration when in EasyMesh mode.
+# This prevents routing loops by ensuring nodes only connect to APs with lower
+# or equal mesh index values, creating a directional topology toward the root.
+CONFIG_NXP_EASYMESH=y
diff --git a/wpa_supplicant/events.c b/wpa_supplicant/events.c
