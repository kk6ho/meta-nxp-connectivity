@@ -68,6 +68,48 @@ static int wpas_select_network_from_last_scan(struct wpa_supplicant *wpa_s,
 					      union wpa_event_data *data);
 #endif /* CONFIG_NO_SCAN_PROCESSING */
 
+#ifdef CONFIG_NXP_EASYMESH
+/**
+ * get_mesh_index_from_beacon_vendor_ies - Extract NXP EasyMesh index from beacon
+ * @bss: BSS entry from scan results
+ * Returns: mesh_idx (1-255) if found, -1 if not present
+ *
+ * Searches for NXP vendor-specific IE (OUI: C0:95:DA:00) in beacon or
+ * probe response frames. The 5th byte contains the mesh index (sequence number)
+ * used for loop avoidance in EasyMesh backhaul topology.
+ *
+ * Vendor IE Format:
+ *   Element ID: 0xDD (Vendor Specific)
+ *   Length: 5
+ *   OUI: C0:95:DA (NXP)
+ *   Type: 00
+ *   Data: mesh_idx (1 byte, value 1-255)
+ */
+static int get_mesh_index_from_beacon_vendor_ies(struct wpa_bss *bss)
+{
+        const u8 *ies;
+        const struct element *elem;
+        if(bss->ie_len > 0){
+                ies = wpa_bss_ie_ptr(bss);
+                for_each_element_id(elem, WLAN_EID_VENDOR_SPECIFIC, ies, bss->ie_len) {
+                        if (elem->datalen == 5 &&
+                                        (os_memcmp(&elem->data[0], "\xc0\x95\xda\x00", 4) == 0))
+                                return elem->data[4];
+                }
+        }
+        else if (bss->beacon_ie_len > 0)
+        {
+                ies = wpa_bss_ie_ptr(bss);
+                ies += bss->ie_len;
+                for_each_element_id(elem, WLAN_EID_VENDOR_SPECIFIC, ies, bss->beacon_ie_len) {
+                        if (elem->datalen == 5 &&
+                                        (os_memcmp(&elem->data[0], "\xc0\x95\xda\x00", 4) == 0))
+                                return elem->data[4];
+                }
+        }
+        return -1;
+}
+#endif
 
