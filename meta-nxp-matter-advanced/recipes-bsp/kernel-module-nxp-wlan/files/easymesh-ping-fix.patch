From 34573efa43cc541289fa921e5ae569c82b0daa8b Mon Sep 17 00:00:00 2001
From: Neeraj Sanjay Kale <neeraj.sanjaykale@nxp.com>
Date: Mon, 2 Mar 2026 14:55:30 +0530
Subject: [PATCH] Issue: WSW-69613 [Easymesh] BH to FH traffic failing on uap0

[Description]
Consider a topology:

  Controller+Agent1 <---> Agent2 <---> Agent3 <--- Agent4

A client connected to Agent3 could ping Agent1, Agent2 and Agent3.
But ping to Agent4 always failed.
Agent4's ARP reply was not forwarded to by Agent3, even though Agent4
and client were connected to same uap0 interface on Agent3.

[Root Cause]
The Agent3 was forwarding the ARP reply in 4-addr mode to client.

[Fix]
Before uap0 forwards a packet on it's interface to other connected
stations, check if that station is a client or a backhaul STA.
If it's not a backhaul STA, then it's a client. So convert the frame
into 3-addr mode.

[Testing]
Client connected to Agent3 is able to ping all Agents, as well as all
other clients connected to different agents, both upstream and
downstream.

Upstream-Status: Inappropriate  [platform specific changes]

Change-Id: 7a814a2e-0dc2-11f1-801c-b7ab2ce656ae
---
 mlan/mlan_uap_txrx.c | 14 +++++++++++---
 1 file changed, 11 insertions(+), 3 deletions(-)

diff --git a/mlan/mlan_uap_txrx.c b/mlan/mlan_uap_txrx.c
index 0d32c3f..e123e9d 100644
--- a/mlan/mlan_uap_txrx.c
+++ b/mlan/mlan_uap_txrx.c
@@ -809,9 +809,17 @@ mlan_status wlan_process_uap_rx_packet(mlan_private *priv, pmlan_buffer pmbuf)
 			}
 		}
 	} else {
-		if ((!(priv->pkt_fwd & PKT_FWD_INTRA_UCAST)) &&
-		    (wlan_get_station_entry(priv,
-					    prx_pkt->eth803_hdr.dest_addr))) {
+		sta_node *dest_sta = wlan_get_station_entry(priv,
+							    prx_pkt->eth803_hdr.dest_addr);
+		if ((!(priv->pkt_fwd & PKT_FWD_INTRA_UCAST)) && dest_sta) {
+			if (prx_pd->flags & RXPD_FLAG_PKT_EASYMESH) {
+				/* This is a 4-address frame from backhaul */
+				if (dest_sta && !dest_sta->is_multi_ap) {
+					/* Destination is a fronthaul client (3-address mode)
+					 * Clear EASYMESH flag to convert 4-addr to 3-addr */
+					pmbuf->flags &= ~MLAN_BUF_FLAG_EASYMESH;
+				}
+			}
 			/* Forwarding Intra-BSS packet */
 #ifdef USB
 			if (IS_USB(pmadapter->card_type)) {
